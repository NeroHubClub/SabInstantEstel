-- ========== DRAG ==========
local dragging = false
local dragInput
local dragStart
local startPos

header.InputBegan:Connect(function(input)
	if window.Active and (input.UserInputType == Enum.UserInputType.MouseButton1 or 
		input.UserInputType == Enum.UserInputType.Touch) then
		dragging = true
		dragStart = input.Position
		startPos = window.Position
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

header.InputChanged:Connect(function(input)
	if window.Active and (input.UserInputType == Enum.UserInputType.MouseMovement or 
		input.UserInputType == Enum.UserInputType.Touch) then
		dragInput = input
	end
end)

UIS.InputChanged:Connect(function(input)
	if window.Active and dragging and input == dragInput then
		local delta = input.Position - dragStart
		window.Position = UDim2.new(
			startPos.X.Scale, 
			startPos.X.Offset + delta.X,
			startPos.Y.Scale, 
			startPos.Y.Offset + delta.Y
		)
	end
end)

