-- Anti-Kick System
local function setupAntiKick()
    if not scriptEnabled then return end
    pcall(function()
        for _, v in pairs(getconnections(plr.Idled)) do
            v:Disable()
        end
    end)
    
    pcall(function()
        game:GetService("ScriptContext").Error:Connect(function() end)
    end)
    
    pcall(function()
        local mt = getrawmetatable(game)
        if mt then
            setreadonly(mt, false)
            local oldNamecall = mt.__namecall
            mt.__namecall = newcclosure(function(self, ...)
                local method = getnamecallmethod()
                if method == "Kick" or method == "kick" then
                    return nil
                end
                return oldNamecall(self, ...)
            end)
            setreadonly(mt, true)
        end
    end)
end

-- God Mode Function
local function activateGodMode()
    if not scriptEnabled or godModeEnabled then return end
    godModeEnabled = true
    
    local function setupCharacter(character)
        if not character then return end
        
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if not humanoid then return end

        pcall(function()
            humanoid.BreakJointsOnDeath = false
            humanoid.RequiresNeck = false
        end)

        pcall(function()
            for _, connection in ipairs(getconnections(humanoid.Died)) do
                connection:Disable()
            end
        end)

        humanoid:GetPropertyChangedSignal("Health"):Connect(function()
            if not scriptEnabled then return end
            pcall(function()
                if humanoid and humanoid.Parent and humanoid.Health < humanoid.MaxHealth then
                    humanoid.Health = humanoid.MaxHealth
                end
            end)
        end)

        RunService.Heartbeat:Connect(function()
            if not scriptEnabled then return end
            pcall(function()
                if humanoid and humanoid.Parent and humanoid.Health < humanoid.MaxHealth then
                    humanoid.Health = humanoid.MaxHealth
                end
            end)
        end)
    end

    setupCharacter(plr.Character)

    plr.CharacterAdded:Connect(function(character)
        if not scriptEnabled then return end
        task.wait(0.5)
        setupCharacter(character)
    end)
end

-- Desync Function
local function executeDesync()
    if not scriptEnabled then return end
    
    local flags = {
        {"GameNetPVHeaderRotationalVelocityZeroCutoffExponent", "-5000"},
        {"LargeReplicatorWrite5", "true"},
        {"AngularVelociryLimit", "360"},
        {"S2PhysicsSenderRate", "15000"},
        {"ServerMaxBandwith", "52"},
        {"PhysicsSenderMaxBandwidthBps", "20000"},
        {"WorldStepMax", "30"},
    }

    for _, data in ipairs(flags) do
        pcall(function()
            if setfflag then
                setfflag(data[1], data[2])
            end
        end)
    end

    local char = plr.Character
    if not char then return end

    local humanoid = char:FindFirstChildWhichIsA("Humanoid")
    if humanoid then
        pcall(function()
            humanoid:ChangeState(Enum.HumanoidStateType.Dead)
        end)
    end

    pcall(function()
        char:ClearAllChildren()

        local fakeModel = Instance.new("Model")
        fakeModel.Name = "FakeCharacter"
        fakeModel.Parent = workspace
        plr.Character = fakeModel
        task.wait(0.1)
        plr.Character = char
        fakeModel:Destroy()
    end)
end

