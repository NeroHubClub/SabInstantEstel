-- ========== TYPE ANIMATION FUNCTION ==========
local function typeAnimation(textLabel, fullText, delayPerChar)
	textLabel.Text = ""
	for i = 1, #fullText do
		textLabel.Text = string.sub(fullText, 1, i)
		wait(delayPerChar)
	end
end

-- ========== ANIMATION SEQUENCE ==========
local function animateReveal()
	gui.Enabled = true
	
	-- Disable dragging
	window.Active = false
	
	-- STEP 1: Frame appears (15s)
	print("Step 1: Frame appearing...")
	TweenService:Create(window, TweenInfo.new(15, Enum.EasingStyle.Quad), {BackgroundTransparency = 0}):Play()
	wait(17)
	
	-- STEP 2: Title typing (20s)
	print("Step 2: Title typing...")
	typeAnimation(title, "Steal A Brainrots | Freeze Trade | v2.1", 0.35)
	wait(5)
	
	-- STEP 3: Author typing (15s)
	print("Step 3: Author typing...")
	typeAnimation(author, "By: Nero", 0.6)
	wait(5)
	
	-- STEP 4: Minimize button (10s)
	print("Step 4: Minimize button...")
	TweenService:Create(hideBtn, TweenInfo.new(10), {BackgroundTransparency = 0, TextTransparency = 0}):Play()
	wait(12)
	
	-- STEP 5: Input field (20s)
	print("Step 5: Input field...")
	tradeFrame.Visible = true
	TweenService:Create(inputContainer, TweenInfo.new(15), {BackgroundTransparency = 0}):Play()
	wait(10)
	
	TweenService:Create(inputLabel, TweenInfo.new(5), {TextTransparency = 0}):Play()
	wait(3)
	
	TweenService:Create(textBox, TweenInfo.new(8), {BackgroundTransparency = 0, TextTransparency = 0}):Play()
	wait(5)
	
	TweenService:Create(victimAvatar, TweenInfo.new(5), {ImageTransparency = 0}):Play()
	wait(7)
	
	-- STEP 6: Toggle frames (15s)
	print("Step 6: Toggle frames...")
	for i, container in ipairs(toggleContainers) do
		TweenService:Create(container, TweenInfo.new(8), {BackgroundTransparency = 0}):Play()
		wait(7)
	end
	wait(5)
	
	-- STEP 7: Toggle text typing (15s)
	print("Step 7: Toggle text typing...")
	local toggleTexts = {"Freeze Trade", "Force to Ready"}
	for i, label in ipairs(toggleLabels) do
		typeAnimation(label, toggleTexts[i], 0.4)
		wait(5)
	end
	wait(5)
	
	-- STEP 8: Toggle switches (15s)
	print("Step 8: Toggle switches...")
	for i, switch in ipairs(toggleSwitches) do
		TweenService:Create(switch, TweenInfo.new(6), {BackgroundTransparency = 0}):Play()
		wait(3)
		
		if toggleThumbs[i] then
			TweenService:Create(toggleThumbs[i], TweenInfo.new(4), {BackgroundTransparency = 0}):Play()
		end
		wait(4)
	end
	wait(5)
	
	-- STEP 9: Trade tab (10s)
	print("Step 9: Trade tab...")
	TweenService:Create(tradeTab, TweenInfo.new(8), {BackgroundTransparency = 0}):Play()
	wait(4)
	TweenService:Create(tradeTab, TweenInfo.new(3), {TextTransparency = 0}):Play()
	wait(5)
	
	-- STEP 10: History tab (10s)
	print("Step 10: History tab...")
	TweenService:Create(historyTab, TweenInfo.new(8), {BackgroundTransparency = 0}):Play()
	wait(4)
	TweenService:Create(historyTab, TweenInfo.new(3), {TextTransparency = 0}):Play()
	wait(5)
	
	-- STEP 11: User avatar and username (15s)
	print("Step 11: User info...")
	TweenService:Create(avatar, TweenInfo.new(10), {ImageTransparency = 0}):Play()
	wait(5)
	typeAnimation(usernameLabel, plr.Name, 0.2)
	wait(8)
	
	print("Animation complete!")
	
	-- Enable all interactive elements
	window.Active = true
	clickDetector.Active = true
	textBox.Active = true
	
	-- Remove blur and loading text
	TweenService:Create(blurOverlay, TweenInfo.new(2), {BackgroundTransparency = 1}):Play()
	TweenService:Create(blurEffect, TweenInfo.new(2), {Size = 0}):Play()
	TweenService:Create(loadingContainer, TweenInfo.new(1), {BackgroundTransparency = 1}):Play()
	TweenService:Create(loadingText, TweenInfo.new(1), {TextTransparency = 1}):Play()
	
	wait(2)
	blurOverlay:Destroy()
	blurEffect:Destroy()
	loadingContainer:Destroy()
	
	-- Load avatars
	task.spawn(function()
		local userId = plr.UserId
		local thumbType = Enum.ThumbnailType.AvatarBust
		local thumbSize = Enum.ThumbnailSize.Size48x48
		local content, isReady = Players:GetUserThumbnailAsync(userId, thumbType, thumbSize)
		if isReady then
			avatar.Image = content
		end
	end)
	
	task.spawn(function()
		local userId = plr.UserId
		local thumbType = Enum.ThumbnailType.AvatarBust
		local thumbSize = Enum.ThumbnailSize.Size120x120
		local content, isReady = Players:GetUserThumbnailAsync(userId, thumbType, thumbSize)
		if isReady then
			popupAvatar.Image = content
		end
	end)
	
	-- Completion notification
	local notification = Instance.new("TextLabel")
	notification.Size = UDim2.new(0, 180, 0, 35)
	notification.Position = UDim2.new(0.5, -90, 0, 10)
	notification.BackgroundColor3 = Color3.fromRGB(16, 16, 22)
	notification.TextColor3 = colors.accent
	notification.Text = "✓ Hub Loaded!"
	notification.Font = Enum.Font.GothamBold
	notification.TextSize = 12
	notification.BackgroundTransparency = 1
	notification.TextTransparency = 1
	notification.ZIndex = 20
	notification.Parent = gui
	
	local notifCorner = Instance.new("UICorner")
	notifCorner.CornerRadius = UDim.new(0, 8)
	notifCorner.Parent = notification
	
	TweenService:Create(notification, TweenInfo.new(1), {BackgroundTransparency = 0.1, TextTransparency = 0}):Play()
	wait(3)
	TweenService:Create(notification, TweenInfo.new(1), {BackgroundTransparency = 1, TextTransparency = 1}):Play()
	wait(1)
	notification:Destroy()
end

