-- DRAGGING SYSTEM (Compatible with PC and Mobile)
local dragging = false
local dragInput = nil
local dragStart = nil
local startPos = nil

local function updateDrag(input)
    local delta = Vector2.new(
        input.Position.X - dragStart.X,
        input.Position.Y - dragStart.Y
    )
    
    mainContainer.Position = UDim2.new(
        startPos.X.Scale,
        startPos.X.Offset + delta.X,
        startPos.Y.Scale,
        startPos.Y.Offset + delta.Y
    )
end

-- Handle input start (Mouse and Touch)
header.InputBegan:Connect(function(input)
    if not scriptEnabled then return end
    
    -- Check if it's mouse button or touch
    if input.UserInputType == Enum.UserInputType.MouseButton1 or 
       input.UserInputType == Enum.UserInputType.Touch then
        
        dragging = true
        dragStart = input.Position
        startPos = mainContainer.Position
        
        -- Visual feedback na na-drag (optional)
        header.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
    end
end)

-- Handle input end
header.InputEnded:Connect(function(input)
    if not scriptEnabled then return end
    
    if input.UserInputType == Enum.UserInputType.MouseButton1 or 
       input.UserInputType == Enum.UserInputType.Touch then
        
        dragging = false
        dragStart = nil
        startPos = nil
        
        -- Return to normal color
        header.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
    end
end)

-- Handle input change/movement
UIS.InputChanged:Connect(function(input, gameProcessed)
    if not scriptEnabled then return end
    if not dragging then return end
    
    if input.UserInputType == Enum.UserInputType.MouseMovement or
       input.UserInputType == Enum.UserInputType.Touch then
        
        -- Update position
        local delta = Vector2.new(
            input.Position.X - dragStart.X,
            input.Position.Y - dragStart.Y
        )
        
        mainContainer.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
end)

-- Alternative simpler approach for mobile (backup)
local function makeMobileDraggable()
    local touchStart = nil
    local frameStart = nil
    
    header.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            touchStart = input.Position
            frameStart = mainContainer.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    touchStart = nil
                    frameStart = nil
                end
            end)
        end
    end)
    
    header.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch and touchStart and frameStart then
            local delta = input.Position - touchStart
            mainContainer.Position = UDim2.new(
                frameStart.X.Scale,
                frameStart.X.Offset + delta.X,
                frameStart.Y.Scale,
                frameStart.Y.Offset + delta.Y
            )
        end
    end)
end

-- Call the mobile draggable function as backup
makeMobileDraggable()

