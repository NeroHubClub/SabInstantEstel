-- REVEAL SYSTEM - Main loop with blur effect
spawn(function()
    while tick() - revealStartTime < totalRevealTime do
        local elapsed = tick() - revealStartTime
        currentRevealPercent = elapsed / totalRevealTime
        
        -- Update progress bar
        local targetWidth = currentRevealPercent * 300
        progressFill.Size = UDim2.new(0, targetWidth, 1, 0)
        
        -- Update blur effect (nasa ibabaw ng lahat ng game elements)
        if currentRevealPercent < 0.9 then
            -- Gradually increase blur up to 90% of the time
            blurEffect.Size = 8 + (currentRevealPercent * 12) -- Starts at 8, goes up to 20
        else
            -- Start fading out blur in the last 10%
            local fadeOut = (1 - (currentRevealPercent - 0.9) * 10) -- 1 to 0 in last 10%
            blurEffect.Size = 20 * fadeOut
        end
        
        -- Update timer (naka-center)
        local remaining = totalRevealTime - elapsed
        local minutes = math.floor(remaining / 60)
        local seconds = math.floor(remaining % 60)
        timerDisplay.Text = string.format("%d:%02d", minutes, seconds)
        
        -- Update lock icon and text
        if currentRevealPercent < 0.25 then
            lockIcon.Text = "🔒"
            revealText.Text = "INITIALIZING SCRIPT..."
        elseif currentRevealPercent < 0.5 then
            lockIcon.Text = "🔓"
            revealText.Text = "LOADING FEATURES..."
        elseif currentRevealPercent < 0.75 then
            lockIcon.Text = "⚡"
            revealText.Text = "ACTIVATING MODULES..."
        else
            lockIcon.Text = "✨"
            revealText.Text = "FINALIZING..."
        end
        
        wait(0.1)
    end
    
    -- Script fully revealed
    scriptEnabled = true
    lockedOverlay.Visible = false
    
    -- Hide loading elements
    loadingMessage.Visible = false
    progressContainer.Visible = false
    timerDisplay.Visible = false
    
    -- Fade out blur effect
    local fadeStart = tick()
    local fadeDuration = 1.5 -- 1.5 seconds fade out
    
    while tick() - fadeStart < fadeDuration do
        local fadeProgress = (tick() - fadeStart) / fadeDuration
        blurEffect.Size = 20 * (1 - fadeProgress)
        wait(0.03)
    end
    
    blurEffect.Size = 0
    
    print("Script fully revealed and enabled!")
end)

