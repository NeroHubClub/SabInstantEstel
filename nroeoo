local function getRandomUsername()
	if math.random(1, 100) <= 70 then
		return usernamePool[math.random(#usernamePool)]
	else
		return "User" .. math.random(1000, 9999)
	end
end

local function getRandomMutations()
	local count = math.random(0, 3)
	if count == 0 then return "" end
	local selected = {}
	for i = 1, count do
		local mut = mutationsList[math.random(#mutationsList)]
		table.insert(selected, mut)
	end
	local unique = {}
	for _, v in ipairs(selected) do
		if not table.find(unique, v) then
			table.insert(unique, v)
		end
	end
	if #unique == 0 then return "" end
	return "[" .. table.concat(unique, ", ") .. "] "
end

local function getRandomPrice()
	local type = math.random(1, 10)
	if type <= 7 then
		local num = math.random(35, 1500)
		return "$" .. num .. "M/s"
	elseif type <= 9 then
		local num = math.random(1, 9) + math.random(0, 9)/10
		return "$" .. string.format("%.1f", num) .. "B/s"
	else
		local num = math.random(12, 99) * 100
		return "$" .. (num/1000) .. "K/s"
	end
end

local function getRandomRarity()
	return rarities[math.random(#rarities)]
end

local function createFeedEntry(username, itemName, mutations, price, rarity)
	local mutationText = mutations ~= "" and mutations .. " " or ""
	local fullText = username .. " Successfully Got\n -> " .. mutationText .. itemName .. " -> " .. rarity .. " " .. price

	local entry = Instance.new("TextLabel")
	entry.Size = UDim2.new(1, -10, 0, 45)
	entry.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
	entry.Text = fullText
	entry.TextColor3 = colors.text
	entry.Font = Enum.Font.Gotham
	entry.TextSize = 10
	entry.TextXAlignment = Enum.TextXAlignment.Left
	entry.TextYAlignment = Enum.TextYAlignment.Top
	entry.BorderSizePixel = 0
	entry.ZIndex = 4
	entry.Parent = feedFrame

	if itemName == "Dragon Cannelloni" then
		entry.TextColor3 = colors.gold
	end

	local entryCorner = Instance.new("UICorner")
	entryCorner.CornerRadius = UDim.new(0, 6)
	entryCorner.Parent = entry

	return entry
end

local function addNewEntry()
	local username = getRandomUsername()
	local item = itemPool[math.random(#itemPool)]
	local mutations = getRandomMutations()
	local price = getRandomPrice()
	local rarity = getRandomRarity()

	local entry = createFeedEntry(username, item, mutations, price, rarity)

	if table.find(rareItems, item) then
		StarterGui:SetCore("SendNotification", {
			Title = "PUBLIC HISTORY!",
			Text = username .. " Got " .. item .. "!",
			Duration = 10
		})
	end

	for _, child in ipairs(feedFrame:GetChildren()) do
		if child:IsA("TextLabel") and child ~= entry then
			child.Position = child.Position + UDim2.new(0, 0, 0, 50)
		end
	end

	entry.Position = UDim2.new(0, 5, 0, 5)

	local children = feedFrame:GetChildren()
	local labels = {}
	for _, child in ipairs(children) do
		if child:IsA("TextLabel") then
			table.insert(labels, child)
		end
	end
	if #labels > 20 then
		table.sort(labels, function(a, b) return a.Position.Y.Offset > b.Position.Y.Offset end)
		for i = 16, #labels do
			labels[i]:Destroy()
		end
	end

	local maxY = 5
	for _, child in ipairs(feedFrame:GetChildren()) do
		if child:IsA("TextLabel") then
			local bottom = child.Position.Y.Offset + child.Size.Y.Offset
			if bottom > maxY then maxY = bottom end
		end
	end
	feedFrame.CanvasSize = UDim2.new(0, 0, 0, maxY + 10)
end

