	table.insert(toggleThumbs, thumb)

	local thumbCorner = Instance.new("UICorner")
	thumbCorner.CornerRadius = UDim.new(1, 0)
	thumbCorner.Parent = thumb

	local toggled = false
	local isActive = false

	local function updateVisuals()
		if toggled then
			switchBg.BackgroundColor3 = colors.switchOn
			thumb.Position = UDim2.new(1, -18, 0.5, -8)
		else
			switchBg.BackgroundColor3 = colors.switchOff
			thumb.Position = UDim2.new(0, 2, 0.5, -8)
		end
	end

	local clickDetector = Instance.new("TextButton")
	clickDetector.Size = UDim2.new(1, 0, 1, 0)
	clickDetector.BackgroundTransparency = 1
	clickDetector.Text = ""
	clickDetector.AutoButtonColor = false
	clickDetector.ZIndex = 7
	clickDetector.Parent = container
	table.insert(toggleButtons, clickDetector)

	-- Fix: Make click detector work properly
	clickDetector.MouseButton1Click:Connect(function()
		if window.Active then
			toggled = not toggled
			updateVisuals()
			if callback then
				callback(toggled)
			end
			print(name .. " toggled:", toggled) -- Debug
		end
	end)

	clickDetector.MouseEnter:Connect(function()
		if window.Active then
			switchBg.BackgroundColor3 = toggled and colors.switchOn:Lerp(Color3.new(1,1,1), 0.2) or colors.switchOff:Lerp(Color3.new(1,1,1), 0.2)
		end
	end)
	
	clickDetector.MouseLeave:Connect(function()
		if window.Active then
			switchBg.BackgroundColor3 = toggled and colors.switchOn or colors.switchOff
		end
	end)

	return {
		SetState = function(state)
			toggled = state
			updateVisuals()
		end,
		GetState = function()
			return toggled
		end
	}
end

