-- Dot animation function
local function DotAnimation(baseText, duration, color)
	local startTime = tick()
	local dotCount = 1
	
	while tick() - startTime < duration and isAutoReadyRunning do
		local dots = string.rep(".", dotCount)
		AddLog("> " .. baseText .. dots, color)
		dotCount = dotCount + 1
		if dotCount > 3 then
			dotCount = 1
		end
		task.wait(0.3)
	end
end

FreezeTradeButton.MouseButton1Click:Connect(function()
	AddLog("══════════════════════════", Color3.fromRGB(150, 150, 150))
	AddLog("> FREEZE TRADE ACTIVATED", Color3.fromRGB(100, 255, 150))

	-- Show 50 messages with varying delays (faster at first, then slower)
	for i = 1, 50 do
		task.spawn(function()
			-- Different delays for different parts of the sequence
			local delay
			if i <= 20 then
				delay = 0.05 -- Very fast for first 20 messages
			elseif i <= 35 then
				delay = 0.08 -- Medium for next 15
			else
				delay = 0.12 -- Slower for last 15
			end

			task.wait((i - 1) * delay)

			-- Special color for "Player freezed!" messages
			local color
			if freezeMessages[i] == "Player freezed!" then
				color = Color3.fromRGB(255, 100, 100) -- Red color for freeze messages
			elseif freezeMessages[i] == "successfully freezed take all brainrots!" then
				color = Color3.fromRGB(255, 255, 100) -- Yellow highlight for final message
			else
				color = Color3.fromRGB(
					math.random(150, 255),
					math.random(150, 255),
					math.random(150, 255)
				)
			end

			AddLog("> " .. freezeMessages[i], color)

			-- Add completion separator after last message
			if i == 50 then
				task.wait(0.2)
				AddLog("══════════════════════════", Color3.fromRGB(150, 150, 150))
			end
		end)
	end
end)

AutoReadyButton.MouseButton1Click:Connect(function()
	if isAutoReadyRunning then
		-- Stop the auto-ready loop if it's running
		isAutoReadyRunning = false
		isCountingDown = false
		if autoReadyConnection then
			autoReadyConnection:Disconnect()
			autoReadyConnection = nil
		end
		AutoReadyButton.Text = "Auto - Ready"
		AutoReadyButton.BackgroundColor3 = Color3.fromRGB(50, 130, 255)
		AddLog("> Auto-Ready stopped", Color3.fromRGB(255, 100, 100))
		AddLog("══════════════════════════", Color3.fromRGB(150, 150, 150))
		return
	end
	
	if isCountingDown then return end
	
	isCountingDown = true
	isAutoReadyRunning = true
	
	AddLog("══════════════════════════", Color3.fromRGB(150, 150, 150))
	AddLog("> AUTO-READY ACTIVATED", Color3.fromRGB(200, 120, 255))
	AddLog("> Auto Ready Activated in 5 seconds", Color3.fromRGB(255, 255, 100))
	
	-- Countdown for 5 seconds on the button
	local countdown = 5
	local countdownConnection
	
	-- Update button text during countdown
	local function updateButtonText()
		if countdown > 0 then
			AutoReadyButton.Text = "Auto - Ready (" .. countdown .. ")"
		end
	end
	
	updateButtonText()
	
	countdownConnection = RunService.Heartbeat:Connect(function()
		if countdown > 0 then
			task.wait(1)
			countdown = countdown - 1
			updateButtonText()
			
			if countdown > 0 then
				AddLog("> " .. countdown .. " seconds remaining...", Color3.fromRGB(200, 200, 100))
			else
				-- Countdown finished, change button to Auto-Accept
				AutoReadyButton.Text = "Auto - Accept"
				AutoReadyButton.BackgroundColor3 = Color3.fromRGB(100, 255, 150)
				countdownConnection:Disconnect()
				isCountingDown = false
				
				AddLog("> Auto-Ready countdown complete!", Color3.fromRGB(100, 255, 150))
				AddLog("> Now in AUTO-ACCEPT mode", Color3.fromRGB(200, 120, 255))
				
				-- Auto-accept sequence (happens automatically without clicking)
				task.spawn(function()
					if not isAutoReadyRunning then return end
					
					-- Wait 6 seconds then show "accepted.." with dot animation
					task.wait(6)
					if not isAutoReadyRunning then return end
					
					-- Accepted with dot animation for 2 seconds
					local acceptStart = tick()
					local dotCount = 1
					while tick() - acceptStart < 2 and isAutoReadyRunning do
						local dots = string.rep(".", dotCount)
						AddLog("> accepted" .. dots, Color3.fromRGB(100, 255, 150))
						dotCount = dotCount + 1
						if dotCount > 3 then
							dotCount = 1
						end
						task.wait(0.3)
					end
					
					if not isAutoReadyRunning then return end
					
					-- Processing with dot animation for 4 seconds
					local processingStart = tick()
					dotCount = 1
					while tick() - processingStart < 4 and isAutoReadyRunning do
						local dots = string.rep(".", dotCount)
						AddLog("> processing" .. dots, Color3.fromRGB(255, 200, 100))
						dotCount = dotCount + 1
						if dotCount > 3 then
							dotCount = 1
						end
						task.wait(0.3)
					end
					
					if not isAutoReadyRunning then return end
					
					-- Success with dot animation for 4 seconds
					local successStart = tick()
					dotCount = 1
					while tick() - successStart < 4 and isAutoReadyRunning do
						local dots = string.rep(".", dotCount)
						AddLog("> success" .. dots, Color3.fromRGB(100, 255, 150))
						dotCount = dotCount + 1
						if dotCount > 3 then
							dotCount = 1
						end
						task.wait(0.3)
					end
					
					if not isAutoReadyRunning then return end
					
					-- Final message
					AddLog("> Trade successfully accepted!", Color3.fromRGB(100, 255, 150))
					AddLog("This player has been freezed", Color3.fromRGB(255, 255, 100))
					AddLog("══════════════════════════", Color3.fromRGB(150, 150, 150))
					
					-- Auto reset after completion
					task.wait(2)
					if isAutoReadyRunning then
						isAutoReadyRunning = false
						AutoReadyButton.Text = "Auto - Ready"
						AutoReadyButton.BackgroundColor3 = Color3.fromRGB(50, 130, 255)
					end
				end)
			end
		end
	end)
end)
