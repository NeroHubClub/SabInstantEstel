-- MINIMIZE FUNCTION
hideBtn.MouseButton1Click:Connect(function()
    if not scriptEnabled then return end
    
    minimized = not minimized
    
    if minimized then
        -- Minimize
        local goal = {
            Size = UDim2.new(0, 400, 0, 40)
        }
        local containerGoal = {
            Size = UDim2.new(0, 400, 0, 40)
        }
        local tween = TweenService:Create(window, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), goal)
        local containerTween = TweenService:Create(mainContainer, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), containerGoal)
        tween:Play()
        containerTween:Play()
        content.Visible = false
        
        -- Hide loading elements
        loadingMessage.Visible = false
        progressContainer.Visible = false
        timerDisplay.Visible = false
        
        hideBtn.Text = "+"
        
        tween.Completed:Connect(function()
            window.Size = UDim2.new(0, 400, 0, 40)
            mainContainer.Size = UDim2.new(0, 400, 0, 40)
        end)
    else
        -- Restore
        local goal = {
            Size = originalSize
        }
        local containerGoal = {
            Size = originalContainerSize
        }
        local tween = TweenService:Create(window, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), goal)
        local containerTween = TweenService:Create(mainContainer, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), containerGoal)
        tween:Play()
        containerTween:Play()
        content.Visible = true
        
        -- Show loading elements if not revealed yet
        if not scriptEnabled then
            loadingMessage.Visible = true
            progressContainer.Visible = true
            timerDisplay.Visible = true
        end
        
        hideBtn.Text = "-"
        
        tween.Completed:Connect(function()
            window.Size = originalSize
            mainContainer.Size = originalContainerSize
        end)
    end
end)

