local function setActiveTab(active)
	if active == "TRADE" then
		tradeTab.BackgroundColor3 = colors.tabActive
		historyTab.BackgroundColor3 = colors.tabInactive
		tradeFrame.Visible = true
		historyFrame.Visible = false
	else
		tradeTab.BackgroundColor3 = colors.tabInactive
		historyTab.BackgroundColor3 = colors.tabActive
		tradeFrame.Visible = false
		historyFrame.Visible = true
	end
end

